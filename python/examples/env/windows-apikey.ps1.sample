$env:BEYONDTRUST_ENABLED = "true"
$env:BEYONDTRUST_API_URL = "https://pam.example.com/BeyondTrust/api/public/v3"
$env:BEYONDTRUST_USE_APP_USER = "false"
$env:BEYONDTRUST_API_KEY = "PS-Auth key=<API_KEY>; runas=<RUNAS_USER>;"
$env:BEYONDTRUST_RUNAS_USER = "<RUNAS_USER>"
$env:BEYONDTRUST_IGNORE_SSL_ERRORS = "false"
$env:BEYONDTRUST_REFRESH_INTERVAL = "300"
$env:BEYONDTRUST_MANAGED_ACCOUNTS = "LinuxProd.root;WindowsProd.administrator"
$env:BEYONDTRUST_ALL_MANAGED_ACCOUNTS_ENABLED = "false"
$env:BEYONDTRUST_SECRET_SAFE_PATHS = "Team/Db,Team/Api"
$env:BEYONDTRUST_ALL_SECRETS_ENABLED = "false"
$env:BT_EXAMPLE_ACCOUNT = "bt.acc.LinuxProd.root"
$env:BT_EXAMPLE_SAFE_PASSWORD = "bt.safe.Team/Db.AppDb.password"
$env:BT_EXAMPLE_SAFE_USERNAME = "bt.safe.Team/Db.AppDb.username"

Write-Host "Environment variables loaded."
Write-Host "Run: python -m turkcell_bt_python.demo_app"
